[user]
	name = Spencer Gilbert
	email = spencer.gilbert@gmail.com
	signingkey = 1C65F31DA4EA6DCC
[includeIf "gitdir:~/Code/optoro/"]
	path = ~/.gitconfig-optoro
[color]
	branch = auto
	diff = auto
	interactive = auto
	pager = true
	status = auto
        ui = true
[color "status"]
	added = green
        changed = yellow
	untracked = red
[core]
	excludesfile = ~/.gitignore_global
[gpg]
	program = gpg
[commit]
	gpgsign = true
